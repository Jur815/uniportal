NODE_ENV=development
PORT=5000

# MongoDB Atlas URI. If the URI contains the literal <PASSWORD>, set DATABASE_PASSWORD.
DATABASE=mongodb+srv://username:<PASSWORD>@cluster.mongodb.net/uniportal
DATABASE_PASSWORD=

# JWT configuration.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend origin for CORS. Use the exact deployed Vercel origin in production.
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=

# Optional demo seed passwords. Leave blank to auto-generate and print in terminal.
DEMO_ADMIN_PASSWORD=
DEMO_REGISTRAR_PASSWORD=
DEMO_STUDENT_PASSWORD=
